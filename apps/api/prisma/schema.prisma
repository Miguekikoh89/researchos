generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(STUDENT)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
  auditLogs AuditLog[]
  @@map("users")
}

enum Role {
  STUDENT
  ADVISOR
  ADMIN
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  datasets Dataset[]
  jobs     AnalysisJob[]
  reports  Report[]
  @@map("projects")
}

model Dataset {
  id           String   @id @default(cuid())
  projectId    String
  originalName String
  storedPath   String
  mimeType     String
  sizeBytes    Int
  rowCount     Int?
  columnCount  Int?
  columns      Json?
  missingPct   Float?
  warnings     Json?
  createdAt    DateTime @default(now())
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  jobs    AnalysisJob[]
  @@map("datasets")
}

model AnalysisJob {
  id         String    @id @default(cuid())
  projectId  String
  datasetId  String
  status     JobStatus @default(PENDING)
  config     Json
  startedAt  DateTime?
  finishedAt DateTime?
  errorMsg   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dataset Dataset        @relation(fields: [datasetId], references: [id])
  result  AnalysisResult?
  @@map("analysis_jobs")
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model AnalysisResult {
  id              String   @id @default(cuid())
  jobId           String   @unique
  method          String
  diagnostic      Json
  descriptives    Json
  reliability     Json
  normality       Json
  correlations    Json
  baremoA         Json?
  baremoB         Json?
  interpretations Json
  warnings        Json
  wordPath        String?
  ttest            Json?
  anova             Json?
  regression        Json?
  logistic          Json?
  chi_square        Json?
  instruments       Json?
  ordinal_regression Json?
  hierarchical_regression Json?
  discriminant      Json?
  ancova            Json?
  frequencies       Json?
  cluster           Json?
  cronbach_only     Json?
  baremos_only      Json?
  descriptives_full Json?
  analisis_descriptivo Json?
  objective String?
  hypothesis_h1 String?
  createdAt       DateTime @default(now())
  job AnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  @@map("analysis_results")
}

model Report {
  id        String     @id @default(cuid())
  projectId String
  type      ReportType
  filePath  String
  fileName  String
  createdAt DateTime   @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@map("reports")
}

enum ReportType {
  WORD_APA
  EXCEL
  JSON
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  resource   String
  resourceId String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  user User @relation(fields: [userId], references: [id])
  @@map("audit_logs")
}
