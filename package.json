{
  "name": "researchos-stats-engine",
  "version": "1.0.0",
  "private": true,
  "description": "ResearchOS Stats Engine — Monorepo",
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "cd apps/api && npm run start:dev",
    "dev:web": "cd apps/web && npm run dev",
    "build:api": "cd apps/api && npm run build",
    "build:web": "cd apps/web && npm run build",
    "db:migrate": "cd apps/api && npm run db:migrate",
    "db:seed": "cd apps/api && npm run db:seed",
    "db:generate": "cd apps/api && npm run db:generate",
    "install:r": "Rscript apps/api/stats-engine-r/install_packages.R",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
