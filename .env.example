# ─────────────────────────────────────────────────────────────────────────────
# ResearchOS Stats Engine — Variables de entorno
# Copia este archivo como .env y completa los valores
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_secure_password

# ── NestJS API (apps/api/.env) ────────────────────────────────────────────────
DATABASE_URL=postgresql://researchos:changeme_secure_password@localhost:5432/researchos
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui
PORT=4000
NODE_ENV=development

# URLs
FRONTEND_URL=http://localhost:3000

# Almacenamiento de archivos
UPLOAD_DIR=/tmp/researchos/uploads
OUTPUT_DIR=/tmp/researchos/outputs

# Motor R
R_ENGINE_PATH=./apps/stats-engine-r/run_analysis.R
R_BIN=Rscript
R_TIMEOUT_MS=120000

# ── Next.js Frontend (apps/web/.env.local) ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
